---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Terms of Service | Winning Plumber' };
---
<Layout metadata={metadata}>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <h1 class="font-bold font-heading text-4xl mb-8">Terms of Service</h1>
    <div class="prose prose-lg dark:prose-invert">
      <p>Welcome to <strong>Winning Plumber</strong>. These terms govern your use of our professional vanity URL services.</p>
      <h3>Service Description</h3>
      <p>Winning Plumber provides technical setup and hosting for vanity booking URLs. We are not a plumbing service provider.</p>
      <h3>One-Time Fee</h3>
      <p>The $99 payment is a one-time setup and license fee. There are no monthly SaaS fees for the lifetime of your configured redirect.</p>
    </div>
  </section>
</Layout>

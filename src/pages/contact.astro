---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import GoogleContactForm from '~/components/widgets/GoogleContactForm.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';

const metadata = {
  title: 'Contact Support | Winning Plumber',
  description: 'Have questions about the lifetime deal for your plumbing business? Contact our team today.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <HeroText 
    tagline="We're in your corner ⭐⭐⭐⭐⭐"
    title="Let's Talk About Your Plumbing Business." 
    subtitle="Have questions about the lifetime deal? Need a bulk discount for multiple trucks? We respond faster than a pipe leak."
  />
  <GoogleContactForm />
  <Features
    class="-mt-16"
    columns={3}
    items={[
      { title: 'Fleet Discounts', description: 'Running a multi-truck operation? Contact us for custom bulk pricing on 3+ locations.', icon: 'tabler:truck' },
      { title: 'White-Glove Support', description: 'Need help with your Google Business Profile? Let us handle the technical side.', icon: 'tabler:headset' },
      { title: 'Partnerships', description: 'Are you a marketing agency for trades? Let’s work together.', icon: 'tabler:users' },
    ]}
  />
  <Hero class="-mt-16" image={{ src: '/images/testimonial-7.webp', alt: 'Winning Plumber success' }} />
</Layout>

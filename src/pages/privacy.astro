---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Privacy Policy | Winning Plumber' };
---
<Layout metadata={metadata}>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <h1 class="font-bold font-heading text-4xl mb-8">Privacy Policy</h1>
    <div class="prose prose-lg dark:prose-invert">
      <p>At <strong>Winning Plumber</strong>, we respect your business privacy. We collect only the data needed to create your professional vanity URL.</p>
      <h3>Data Security</h3>
      <p>We do not store customer appointment data. Any customer information entered into your booking system is handled by your primary software provider (e.g., ServiceTitan, Housecall Pro).</p>
    </div>
  </section>
</Layout>

---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Privacy Policy | Winning Plumber' };
---
<Layout metadata={metadata}>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <h1 class="font-bold font-heading text-4xl mb-8">Privacy Policy</h1>
    <div class="prose prose-lg dark:prose-invert">
      <p>At <strong>Winning Plumber</strong>, we respect your business data. We collect only the information necessary to create your professional vanity URL and sync your dispatch system.</p>
      <p>We do not store homeowner data or payment details on our servers; all booking transactions occur through your chosen primary booking provider.</p>
    </div>
  </section>
</Layout>

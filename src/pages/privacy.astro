---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Privacy Policy | Winning Plumber' };
---
<Layout metadata={metadata}>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <h1 class="font-bold font-heading text-4xl mb-8">Privacy Policy</h1>
    <div class="prose prose-lg max-w-4xl dark:prose-invert">
      <p>At <strong>Winning Plumber</strong>, we respect the privacy of plumbing professionals and their customers.</p>
      <h2 class="text-2xl font-bold mt-8">Data Collection</h2>
      <p>We collect essential business information to facilitate your professional URL setup. We do not sell your data to third-party marketers.</p>
      <h2 class="text-2xl font-bold mt-8">Security</h2>
      <p>Payments are handled via secure third-party processors. Winning Plumber does not store sensitive financial or patient/customer scheduling data on our servers.</p>
    </div>
  </section>
</Layout>

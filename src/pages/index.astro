---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import { headerData } from '~/navigation';
import FAQs from '~/components/widgets/FAQs.astro';
import { lifetimeDeal } from '~/data/pricingData';

const metadata = { 
  title: 'Winning Plumber | Professional Vanity URLs for Plumbers', 
  description: 'Ditch generic links. Get a professional booking URL on winningplumber.com and rank higher on Google Maps.' 
};
---
<Layout metadata={metadata}>
  <Fragment slot="header"><Header {...headerData} isSticky /></Fragment>
  <Hero2
    tagline="Boutique Web Development for Plumbers"
    title='<span class="text-accent dark:text-white">Your Business. Your Domain. More Jobs.</span>'
    subtitle="Ugly booking links drive customers away. We build you a professional vanity URL (yourname.winningplumber.com) that connects directly to your Google 'Schedule' button. One-time setup, zero monthly fees."
    actions={[{ variant: 'primary', text: 'Secure Your URL Now', href: '/pricing/' }, { text: 'How It Works', href: '#howitworks' }]}
    image={{ src: '/images/hero-poster.webp', width: 1024, height: 576 }}
  />
  <Features
    id="features"
    title="Dominate Your Local Area"
    items={[
        { title: 'The Google "Schedule" Button', description: 'We help you link your professional URL to the official Google Business button so homeowners can book instantly.', icon: 'tabler:brand-google' },
        { title: 'Memorable Vanity URLs', description: 'Stop using long, confusing links. Get a clean address that homeowners can actually remember and share.', icon: 'tabler:link' },
        { title: 'Mobile-First Dispatch', description: 'Optimized for customers on their phones during plumbing emergencies. Fast, clean, and professional.', icon: 'tabler:device-mobile' },
        { title: 'Same-Day Delivery', description: 'Order by 2PM and have your custom professional booking link live before you finish your next service call.', icon: 'tabler:bolt' },
    ]}
  />
  <div id="howitworks" class="scroll-mt-20">
    <Steps2
      title="Professional Setup in 3 Steps"
      items={[
        { title: '1. Claim Your Brand', description: 'Pick your custom plumbing vanity name and secure the lifetime license.', icon: 'tabler:number-1' },
        { title: '2. We Build the Portal', description: 'Our team builds your mobile-optimized landing page and syncs it with your calendar.', icon: 'tabler:number-2' },
        { title: '3. Book More Jobs', description: 'Link it to Google, Yelp, and your truck magnets. Start filling your dispatch schedule instantly.', icon: 'tabler:number-3' },
      ]}
      image={{ src: '/images/testimonial-6.webp', alt: 'Plumbing dispatch interface' }}
    />
  </div>
  <Pricing title='One-Time Payment. Lifetime Commercial License.' prices={[lifetimeDeal]} />
  <FAQs
    title="Plumber FAQs"
    items={[
        { title: 'What is a Vanity URL?', description: 'Instead of a link like "booking.sq.com/123-xyz", you get <strong>yourname.winningplumber.com</strong>. It looks like you own a massive tech-forward plumbing company.', icon: 'tabler:link' },
        { title: 'Does this replace my dispatch software?', description: 'No. We act as the professional "Front Door." We can link Winning Plumber to Housecall Pro, ServiceTitan, or any system you already use.', icon: 'tabler:tool' },
    ]}
  />
</Layout>

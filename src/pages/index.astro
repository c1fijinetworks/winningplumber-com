---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import { headerData } from '~/navigation';
import FAQs from '~/components/widgets/FAQs.astro';
import { lifetimeDeal } from '~/data/pricingData';

const metadata = { 
  title: 'Winning Plumber | Professional Vanity URLs for Contractors', 
  description: 'Replace generic links with a beautiful dispatch page on your own professional domain. Instant Google Business Profile integration.' 
};
---
<Layout metadata={metadata}>
  <Fragment slot="header">
    <Header {...headerData} isSticky />
  </Fragment>

  <Hero2
    tagline="Boutique Web Development for Plumbers"
    title='<span class="text-accent dark:text-white">Your Business. Your Domain. Your Rules.</span>'
    subtitle="Generic dispatch links look cheap. We build you a professional vanity booking URL (yourname.winningplumber.com) that integrates directly with your Google Business 'Book Online' button. Same-day setup, zero tech stress."
    actions={[
      { variant: 'primary', text: 'Get Your Vanity URL Today', href: '/pricing/' }, 
      { text: 'See How It Works', href: '#howitworks' }
    ]}
    image={{ src: '/images/hero-poster.webp', width: 1024, height: 576 }}
  />

  <Features
    class="-mt-16"
    id="features"
    title="Dominate Your Local Market"
    items={[
        { title: 'The "Book Online" Button Pro', description: 'We help you link your vanity URL to the official Google "Book Online" button so homeowners can dispatch you directly from Search.', icon: 'tabler:brand-google' },
        { title: 'Instant Vanity URLs', description: 'Ditch the long, ugly ID strings from your dispatch software. Own a clean link your customers can actually read.', icon: 'tabler:link' },
        { title: 'Professional Branding', description: 'Every URL is custom-styled to match your company logo, truck wraps, and brand colors.', icon: 'tabler:palette' },
        { title: 'Same-Day Delivery', description: 'If you order by 2PM, your vanity URL and booking portal are live before your final service call of the day.', icon: 'tabler:bolt' },
    ]}
  />

  <Content
    class="-mt-16"
    items={[
        { title: 'Build Instant Trust & Authority', description: 'When a homeowner is standing in an inch of water, they want a professional. A custom domain immediately proves you are an established, premium service provider.', icon: 'tabler:award' },
        { title: 'Showcase Your Reliability', description: 'We design your dispatch page to act as a high-end digital business card, building instant trust with new visitors 24/7.', icon: 'tabler:user-check' },
        { title: 'Beat the Competition', description: 'When homeowners compare local plumbers, the one with a professional domain and seamless mobile experience always wins.', icon: 'tabler:trending-up' },
        { title: 'Mobile-First Priority', description: 'Our pages are optimized for the emergency booking flow, ensuring zero friction for panicked mobile users.', icon: 'tabler:device-mobile' },
    ]}
    image={{ src: '/images/testimonial-2.webp', alt: 'Professional plumbing work' }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        <span class="text-accent dark:text-white">Why a Vanity URL is Your Best Digital Handshake</span>
      </h3>
    </Fragment>
    <Fragment slot="bg"><div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div></Fragment>
  </Content>

  <div id="howitworks" class="scroll-mt-20">
    <Steps2
      title="Same-Day Professional Setup"
      subtitle="Three simple steps to claim your professional identity."
      items={[
        { title: 'Step 1: Claim Your URL', description: 'Pick your vanity name and secure the $99 lifetime license.', icon: 'tabler:number-1' },
        { title: 'Step 2: We Build The Engine', description: 'Our team builds your mobile-first booking app and styles it to your brand.', icon: 'tabler:number-2' },
        { title: 'Step 3: Sync & Dispatch', description: 'We help you drop the link into your Google Profile and social media. Start taking emergency calls instantly.', icon: 'tabler:number-3' },
      ]}
      image={{ src: '/images/testimonial-6.webp', alt: 'Plumbing dispatch interface' }}
    />
  </div>

  <Pricing 
    title='<span class="text-accent dark:text-white">One-Time Investment. Forever Access.</span>' 
    prices={[lifetimeDeal]} 
  />

  <FAQs
    class="-mt-16 px-6"
    title="Deep Dive: How Winning Plumber Works"
    subtitle="Everything you need to know about upgrading your company's digital presence."
    items={[
        { title: 'What exactly is a "Vanity URL"?', description: 'Most dispatch software gives you a messy link like "book.housecallpro.com/u/123-abc". We replace that with a clean, branded address like <strong>smithbros.winningplumber.com</strong>.', icon: 'tabler:link' },
        { title: 'How do you help with Google Business Profiles?', description: 'We provide a step-by-step "White-Glove" guide to linking your new URL to the blue "Book Online" button on your Google Business listing.', icon: 'tabler:brand-google' },
        { title: 'Is it really "Same-Day" Setup?', description: 'Yes. Once you provide your basic info (company name and dispatch link), we deploy your custom URL within hours.', icon: 'tabler:bolt' },
        { title: 'Do I need to cancel my existing dispatch software?', description: 'No! You can use Winning Plumber as a beautiful custom "front-door" that cleanly redirects into bulky dispatch systems like Housecall Pro, Jobber, or ServiceTitan.', icon: 'tabler:device-laptop' },
    ]}
  >
     <Fragment slot="bg"><div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div></Fragment>
  </FAQs>
</Layout>

---
import Hero from '~/components/widgets/Hero.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Content from '~/components/widgets/Content.astro';
import Layout from '~/layouts/PageLayout.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import { lifetimeDeal } from '~/data/pricingData';

const metadata = {
  title: 'Our Mission - Winning Plumber | Built for Contractors',
  description: 'We built Winning Plumber because your service is essential, but business is about trust. Learn how we help contractors dominate digital dispatch.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
<Hero2
    tagline="The Professional Standard ⭐⭐⭐⭐⭐"
    title='You Fix the Pipes.<br/><span class="text-accent dark:text-white">We Build Your Digital Handshake.</span>'
    subtitle="Amazing contractors lose jobs to generic dispatch links. We ensure your digital presence matches your skill. No monthly fees—just a professional, automated system to keep your trucks rolling."
    actions={[
      { variant: 'primary', text: 'Claim My Lifetime Access - $99', href: '/pricing/' },
    ]}
  />

  <Content
    isReversed
    items={[
        { title: 'The Premium First Impression', description: 'When a homeowner clicks "Book Online" on Google, they should see your brand, not a generic software screen. Our vanity URLs provide instant elite status.', icon: 'tabler:sparkles' },
        { title: 'Local Search SEO', description: 'Google prioritizes businesses with high-quality, branded links. Our winningplumber domains signal to Google that you are an established local pro.', icon: 'tabler:map-pin' },
        { title: 'Zero Friction Booking', description: 'Our mobile-first UX is optimized for homeowners booking emergency dispatch on the go, preventing drop-off during panic moments.', icon: 'tabler:users' },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Why your business needs <span class="text-accent">A Professional Vanity URL ⭐⭐⭐⭐⭐</span>
      </h3>
      <p>Homeowners look at screens, not yellow pages. Your URL is your digital handshake—we make sure yours is a 5-star introduction.</p>
    </Fragment>
    <Fragment slot="image">
       <img src="/images/testimonial-4.webp" alt="Professional plumbing tools" class="rounded-lg shadow-xl w-full" />
    </Fragment>
  </Content>

  <Content
    items={[
      { title: 'Zero Maintenance', description: 'We know you’re busy in the field. Once we set up your vanity URL, you never have to log in or "manage" anything technical.', icon: 'tabler:settings' },
      { title: 'White-Glove Integration', description: 'We handle the Google Business Profile link setup for you, ensuring your "Book Online" button points exactly where it should.', icon: 'tabler:stars' },
      { title: 'One-Time Payment', description: 'We don’t believe in monthly fees that eat your profits. $99 once, and you own the system for life.', icon: 'tabler:coin' },
    ]}
  >
    <Fragment slot="content">
      <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
        Our Commitment to Your Success
      </h2>
      <p class="text-xl text-muted dark:text-slate-400 mb-8">
        We aren't just another software company. We are a partner in your growth. We handle the technical hurdles so you can stay focused on the job.
      </p>
    </Fragment>
    <Fragment slot="image">
      <img src="/images/testimonial-3.webp" alt="Plumbing business growth" class="rounded-lg shadow-xl w-full" />
    </Fragment>
  </Content>

  <Pricing
    class="pb-0"
    title={`<span class="text-accent dark:text-white">Invest in Your Professional Future.</span>`}
    prices={[lifetimeDeal]}
  />

  <Hero class="-mt-16">
    <Fragment slot="image">
      <img src="/images/testimonial-6.webp" alt="A professional booking interface" class="mx-auto rounded-md w-full shadow-lg" loading="lazy" />
    </Fragment>
  </Hero>
</Layout>
